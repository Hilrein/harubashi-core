# ── Database ──────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── LLM Provider: anthropic | openai | google | proxy ────
HARUBASHI_LLM_PROVIDER=anthropic

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Google Gemini (OAuth 2.0) ─────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_GEMINI_MODEL=

# ── Proxy (OpenAI-compatible endpoint) ────────────────────
HARUBASHI_PROXY_BASE_URL=
HARUBASHI_PROXY_API_KEY=
HARUBASHI_PROXY_MODEL=

# ── Command Guard ─────────────────────────────────────────
HARUBASHI_SAFE_COMMANDS=ls,cat,echo,pwd,whoami,date,head,tail,wc,find,which
HARUBASHI_COMMAND_TIMEOUT=30000

# ── Analytics (optional) ──────────────────────────────────
HARUBASHI_ANALYTICS_ENDPOINT=
